# ──────────────────────────────────────────────────────────────
#  BrinX — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit your actual .env to version control.
# ──────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
# Port the backend server will listen on
PORT=5003

# ── Database ──────────────────────────────────────────────────
# Option 1 · Local MongoDB (default for development)
MONGODB_URI=mongodb://localhost:27017/brinx

# Option 2 · MongoDB Atlas (cloud — recommended for production)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/brinx?retryWrites=true&w=majority

# ── Authentication ────────────────────────────────────────────
# Strong random secret used to sign JWT tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# ── Environment ───────────────────────────────────────────────
NODE_ENV=development
# NODE_ENV=production

# ── Google OAuth ──────────────────────────────────────────────
# Get this from Google Cloud Console (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Email Service ─────────────────────────────────────────────
# Use "ethereal" for local testing (no real emails sent — preview URL logged in console)
# Use "gmail"   for production (real emails via Gmail SMTP)
EMAIL_SERVICE=ethereal

# Required only when EMAIL_SERVICE=gmail
# EMAIL_USER=your.gmail@gmail.com
# EMAIL_PASS=your_gmail_app_password    # Use an App Password, not your account password
# EMAIL_FROM="BrinX <your.gmail@gmail.com>"

# ── Frontend URL (for password reset links) ───────────────────
# Change this to your deployed URL in production
FRONTEND_URL=http://localhost:5003
